{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "russian-europe-portal",
  "compatibility_date": "2026-07-08",
  "main": ".open-next/worker.js",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  }
}
